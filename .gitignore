# ============================================================================
# DEPENDENCIES & PACKAGES
# ============================================================================
# Node modules (never commit these; they are massive and easily reinstalled)
node_modules/
**/node_modules/
/.pnp
.pnp.js

# Local package manager locks
# Uncomment only if you want to enforce one manager across the repo
# yarn.lock
# package-lock.json
# pnpm-lock.yaml

# ============================================================================
# ENVIRONMENT VARIABLES & SECRETS
# ============================================================================
# Contains database URIs, JWT secrets, API keys, etc.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
/.env
/.env.*
**/.env
**/.env.*

# ============================================================================
# PRODUCTION BUILDS & OUTPUTS
# ============================================================================
# Build outputs
dist/
/dist/
build/
/build/
.next/
out/
/frontend/build/
/frontend/dist/

# ============================================================================
# LOCAL APP DATA & DATABASE FILES
# ============================================================================
backend/data/
backend/data/*
data/
*.db
*.sqlite
*.sqlite3

# ============================================================================
# LOG FILES
# ============================================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log
logs/

# ============================================================================
# TESTING & COVERAGE
# ============================================================================
coverage/
**/coverage/
*.lcov

# ============================================================================
# IDE, EDITOR, AND OS FILES
# ============================================================================
.DS_Store
/.DS_Store
Thumbs.db
.vscode/
*.sublime-project
*.sublime-workspace
.idea/
*.swp
*.bak
*.tmp
.eslintcache
